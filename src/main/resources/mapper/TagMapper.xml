<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lyh.linkhub.mapper.TagMapper">
    <select id="selectIdByName" resultType="java.lang.Long">
        SELECT id FROM tag WHERE name = #{name}
    </select>

    <insert id="insertIfNotExists">
        INSERT IGNORE INTO tag (name) VALUES (#{name})
    </insert>
</mapper>
